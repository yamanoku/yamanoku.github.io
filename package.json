{
  "name": "yamanoku.github.io",
  "author": "yamanoku <0910yama@gmail.com>",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/build-presentations.mjs",
    "preview": "astro preview",
    "lint": "pnpm run biome && pnpm run markuplint",
    "biome": "biome check --write .",
    "biome:ci": "biome ci .",
    "markuplint": "markuplint 'dist/*.html' 'dist/en/**/*.html'",
    "yama-normalize": "pnpm -C packages/yama-normalize"
  },
  "dependencies": {
    "@tailwindcss/vite": "catalog:website",
    "astro": "catalog:website",
    "modern-normalize": "catalog:website",
    "tailwindcss": "catalog:website",
    "vite": "catalog:website"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:website",
    "markuplint": "catalog:website"
  },
  "workspaces": [
    "packages/*",
    "presentations"
  ],
  "engines": {
    "pnpm": "11.6.0",
    "npm": "please_use_pnpm_instead"
  },
  "packageManager": "pnpm@11.6.0"
}
